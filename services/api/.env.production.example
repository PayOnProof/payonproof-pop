# POP API - Production (Mainnet)
POP_ENV=production

# Public web origin (no trailing slash)
WEB_ORIGIN=https://app.yourdomain.com
# Optional explicit list for CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
PAYMENT_LINK_BASE_URL=https://app.yourdomain.com
SEP7_ORIGIN_DOMAIN=app.yourdomain.com
SEP7_CALLBACK_BASE_URL=https://api.yourdomain.com
# Optional; falls back to SEP10_CLIENT_DOMAIN_SIGNING_SECRET when omitted.
SEP7_URI_SIGNING_SECRET=
SEP10_CLIENT_DOMAIN=app.yourdomain.com

# Strong secrets (>= 32 random chars recommended)
EXECUTION_STATE_SECRET=replace_with_long_random_secret
ANCHOR_CALLBACK_SECRET=replace_with_long_random_secret
CRON_SECRET=replace_with_long_random_secret

# Stellar Mainnet
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# Optional for diagnostics endpoint sep10_token
STELLAR_ESCROW_SECRET=

# Anchor discovery / sync
ANCHOR_DISCOVERY_MODE=directory
ANCHOR_ENABLE_HORIZON_FALLBACK=true
STELLAR_ANCHOR_DIRECTORY_URL=
ANCHOR_DIRECTORY_ALLOWED_DOMAINS=

# Optional callback URL customization
SEP24_CALLBACK_BASE_URL=https://api.yourdomain.com
SEP24_CALLBACK_URL_PARAM=callback

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Route output cap
MAX_COMPARE_ROUTES=12

# FX
FX_PROVIDER_URL=https://api.frankfurter.app/latest
FX_FALLBACK_RATE=1
